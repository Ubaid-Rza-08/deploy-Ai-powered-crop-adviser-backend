# ─── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Maven build output ───────────────────────────────────────────────────────
**/target/
**/*.jar
**/*.war
**/*.class

# ─── Node / React ─────────────────────────────────────────────────────────────
**/node_modules/
**/build/
**/.npm

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
**/*.iml
.vscode/
**/*.classpath
**/*.project
**/*.factorypath
**/.settings/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ─────────────────────────────────────────────────────────────────────
**/*.log
**/logs/

# ─── Docker ───────────────────────────────────────────────────────────────────
