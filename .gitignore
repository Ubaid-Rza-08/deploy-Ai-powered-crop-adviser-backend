**/docker-compose.override.yml

# ─── Test reports ─────────────────────────────────────────────────────────────
**/surefire-reports/
**/failsafe-reports/

# ─── Terraform ────────────────────────────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfvars
*.tfstate
*.tfstate.*
.terraform/